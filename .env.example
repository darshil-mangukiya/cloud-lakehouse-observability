# Local Docker development defaults only. Replace every credential for non-local use.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=lakehouse
POSTGRES_USER=lakehouse
POSTGRES_PASSWORD=change_me_local_only
MINIO_ROOT_USER=minio_local
MINIO_ROOT_PASSWORD=change_me_local_only
MINIO_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=minio_local
AWS_SECRET_ACCESS_KEY=change_me_local_only
AWS_DEFAULT_REGION=us-east-1
AIRFLOW_UID=50000
AIRFLOW_WEBSERVER_SECRET_KEY=change_me_local_only
AIRFLOW_ADMIN_PASSWORD=change_me_local_only
